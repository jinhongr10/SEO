# WordPress REST
WP_BASE_URL=https://example.com
WP_USER=your_wp_user
WP_APP_PASSWORD=your_app_password
# Optional JWT auth. If set, it will be used instead of Basic Auth.
# WP_JWT=your_jwt_token

# SFTP (Cloudways-compatible)
SFTP_HOST=example.sftp.host
SFTP_PORT=22
SFTP_USER=master
SFTP_PASSWORD=your_sftp_password
# Optional: private key auth
# SFTP_PRIVATE_KEY_PATH=/absolute/path/to/key.pem

REMOTE_WP_ROOT=/home/master/applications/<app_id>/public_html
UPLOADS_RELATIVE=wp-content/uploads

CONCURRENCY=5
PER_PAGE=100
MAX_PAGES=9999
DRY_RUN=true

# LLM Configuration
LLM_PROVIDER=none # Options: none, gemini
GEMINI_API_KEY= # Required if LLM_PROVIDER=gemini
# LLM_API_KEY= # Deprecated/Custom
DEFAULT_KEYWORDS=soap dispenser,paper towel dispenser,commercial restroom
ALT_MAX_CHARS=125

# Network proxy (e.g. Clash, V2Ray). Uncomment if Node.js cannot reach WP directly.
# HTTPS_PROXY=http://127.0.0.1:7890

RATE_LIMIT_MS=120
RETRY_COUNT=3

DB_PATH=state/media-optimizer.db
CACHE_ORIGINAL_DIR=cache/original
CACHE_OPTIMIZED_DIR=cache/optimized
BACKUP_REMOTE_DIR=backup/remote
